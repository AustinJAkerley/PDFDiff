{
  "manifest_version": 3,
  "name": "PDF Side by Side",
  "version": "0.1.0",
  "description": "Open two local PDFs side by side in one browser tab.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "PDF Side by Side"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "pdf-diff@pdfdiff.local",
      "strict_min_version": "115.0"
    }
  }
}
